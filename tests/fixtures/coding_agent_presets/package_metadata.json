{
  "name": "@acme/checkout-web",
  "version": "2.4.1",
  "description": "Checkout application used by coding-agent preset tests",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.4.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stripe/stripe-js": "2.4.0",
    "@tanstack/react-query": "5.52.0",
    "date-fns": "3.6.0",
    "decimal.js": "10.4.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.23.8",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@testing-library/react": "15.0.7",
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@vitejs/plugin-react": "4.3.1",
    "eslint": "9.8.0",
    "typescript": "5.5.4",
    "vite": "5.3.5",
    "vitest": "2.0.5"
  },
  "generatedMetadata": {
    "hashes": [
      "entry-001",
      "entry-002",
      "entry-003",
      "entry-004",
      "entry-005",
      "entry-006"
    ]
  }
}
