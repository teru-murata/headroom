+use crate::errors::AuthError;
+use crate::session::Session;
+
+pub fn require_user_session(session: &Session) -> Result<&str, AuthError> {
+    let user_id = session.user_id.as_deref().ok_or(AuthError::MissingUser)?;
+    if user_id.is_empty() {
+        return Err(AuthError::MissingUser);
+    }
+    Ok(user_id)
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn rejects_missing_user_session() {
+        let session = Session { user_id: None };
+        assert!(matches!(
+            require_user_session(&session),
+            Err(AuthError::MissingUser)
+        ));
+    }
+
+    #[test]
+    fn accepts_authenticated_user_session() {
+        let session = Session { user_id: Some("user_123".to_string()) };
+        assert_eq!(require_user_session(&session).unwrap(), "user_123");
+    }
+}
